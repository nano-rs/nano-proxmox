<clickhouse>
  <!-- Docs: <https://clickhouse.com/docs/operations/settings/settings_users/> -->
  <!--
    NAN-807 bug #2: passwords are sourced from env vars passed into the
    container (CLICKHOUSE_NANOSIEM_PASSWORD / CLICKHOUSE_ADMIN_PASSWORD) so
    each deployment gets per-install random secrets without baking creds
    into version-controlled XML.
  -->
  <users>
    <!-- Admin user for migrations (DDL enabled) -->
    <nanosiem_admin>
      <profile>admin</profile>
      <networks>
        <ip>::/0</ip>
      </networks>
      <password from_env="CLICKHOUSE_ADMIN_PASSWORD"/>
      <quota>default</quota>
      <access_management>1</access_management>
      <allow_ddl>1</allow_ddl>
    </nanosiem_admin>

    <!-- Runtime user for queries (no DDL for security) -->
    <nanosiem>
      <profile>default</profile>
      <networks>
        <ip>::/0</ip>
      </networks>
      <password from_env="CLICKHOUSE_NANOSIEM_PASSWORD"/>
      <quota>default</quota>
      <access_management>0</access_management>
      <allow_ddl>0</allow_ddl>
      <!-- Grant access to nanosiem database -->
      <grants>
        <query>GRANT SELECT, INSERT, ALTER, CREATE, DROP ON nanosiem.*</query>
        <query>GRANT dictGet ON nanosiem.*</query>
        <query>GRANT SELECT(bytes_on_disk, rows, data_uncompressed_bytes, partition, database, table, active) ON system.parts</query>
        <query>GRANT SELECT(total_space, free_space, type) ON system.disks</query>
      </grants>
    </nanosiem>
  </users>
</clickhouse>
